{
  "name": "gzh-mcp",
  "version": "1.0.2",
  "description": "MCP server for publishing Markdown articles directly to 微信公众号 with elegant built-in themes and preview support.",
  "author": "chef-guo",
  "license": "Apache-2.0",
  "keywords": [
    "公众号",
    "markdown",
    "wechat",
    "publishing",
    "renderer",
    "mcp"
  ],
  "type": "module",
  "bin": {
    "gzh-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/chef-guo/gzh-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chef-guo/gzh-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/chef-guo/gzh-mcp/issues"
  },
  "scripts": {
    "build": "tsc",
    "inspector": "pnpm build && node ./run-inspector.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --fix",
    "test:list": "pnpm build && node --env-file=.env.test ./tests/list.js",
    "test:publish": "pnpm build && node --env-file=.env.test ./tests/publish.js",
    "test:register": "pnpm build && node --env-file=.env.test ./tests/registerTheme.js",
    "test:remove": "pnpm build && node --env-file=.env.test ./tests/removeTheme.js",
    "upgrade:core": "pnpm update chef-md",
    "prepublishOnly": "pnpm upgrade:core && pnpm build"
  },
  "packageManager": "pnpm@10.7.1",
  "dependencies": {
    "@modelcontextprotocol/sdk": "0.6.0",
    "chef-md": "^1.0.0",
    "form-data-encoder": "^4.1.0",
    "formdata-node": "^6.0.3",
    "jsdom": "^27.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/inspector": "^0.21.1",
    "@types/node": "^24.10.7",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "openai": "^6.16.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1"
  }
}
